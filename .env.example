# Google Gemini AI — Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Supabase — Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Demo access password — protects /demo page and pipeline API
DEMO_PASSWORD=

# Google OAuth — Get these from Google Cloud Console > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Slack Incoming Webhook — Get from api.slack.com/apps > Incoming Webhooks
SLACK_WEBHOOK_URL=
DEMO_SLACK_WEBHOOK_URL=

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=

# Site URL — used in Slack digest link (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
